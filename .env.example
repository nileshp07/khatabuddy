# Copy to `.env` and fill in from your Firebase project's web app config.
# All EXPO_PUBLIC_* vars are inlined into the client bundle at build time.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Local development against the Firebase Emulator Suite (no real project needed):
#   1. npm i -g firebase-tools
#   2. firebase emulators:start
#   3. set the two vars below
# On Android emulators use EXPO_PUBLIC_EMULATOR_HOST=10.0.2.2
EXPO_PUBLIC_USE_EMULATOR=false
EXPO_PUBLIC_EMULATOR_HOST=localhost
